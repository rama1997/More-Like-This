# TMDB API Key - Get yours at https://www.themoviedb.org/settings/api
TMDB_API_KEY = your_tmdb_api_key_here

# Trakt API Key - Get yours at https://trakt.tv/oauth/applications
TRAKT_API_KEY = your_trakt_api_key_here

# Gemini API Key - Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY = your_gemini_api_key_here

# RPDB API Key - Get yours at https://ratingposterdb.com/api-key/
RPDB_API_KEY = your_RPDB_api_key_here

# TasteDive API Key - Get yours at https://tastedive.com/account/api_access
TASTEDIVE_API_KEY = your_tastedive_api_key_here